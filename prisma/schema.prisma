// WorkOS — AI Operating System dla gastronomii
// Schemat danych: PostgreSQL, multi-tenant (Organization), RBAC oparty na uprawnieniach.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// ENUMY (porządkowanie modeli danych — integralność na poziomie bazy)
// ──────────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  EMPLOYEE
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  ABSENT
  LATE
}

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ChecklistType {
  OPENING
  CLOSING
  CUSTOM
}

enum ChecklistRunStatus {
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VacationType {
  ANNUAL
  ON_DEMAND
  UNPAID
  SICK
  OTHER
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TASK
  SCHEDULE
  VACATION
}

// ──────────────────────────────────────────────────────────────────────────
// TENANT
// ──────────────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE") // FREE | PRO | ENTERPRISE
  settings  Json     @default("{}") // konfiguracja org (waluta, VAT, model napiwków, polityka void itd.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  locations          Location[]
  schedules          Schedule[]
  shifts             Shift[]
  shiftSwaps         ShiftSwap[]
  tasks              Task[]
  checklistTemplates ChecklistTemplate[]
  checklistRuns      ChecklistRun[]
  wasteReports       WasteReport[]
  incidents          Incident[]
  vacations          Vacation[]
  notifications      Notification[]
  messages           Message[]
  availability       Availability[]
  inventories        Inventory[]
  productions        Production[]
  products           Product[]
  suppliers          Supplier[]
  inventoryItems     InventoryItem[]
  recipes            Recipe[]
  stockMovements     StockMovement[]
  sales              Sale[]
  posConnection      PosConnection?
  cooReviews         CooReview[]
  invoices           Invoice[]
  ksefConnection     KsefConnection?
  alerts             Alert[]
  sopDocuments       SopDocument[]
  auditLogs          AuditLog[]
  zones              Zone[]
  restaurantTables   RestaurantTable[]
  tableOrders        TableOrder[]
  cashSessions       CashSession[]
  reservations       Reservation[]
}

// ──────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  email       String   @unique
  password    String
  role        Role     @default(EMPLOYEE)
  permissions String[] @default([]) // dodatkowe uprawnienia nadane pracownikowi
  hourlyRate  Float    @default(0)  // stawka godzinowa (koszt pracy)
  avatar      String?
  phone       String?
  position    String?
  hireDate    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  shifts         Shift[]
  tasks          Task[]         @relation("TaskAssignee")
  tasksCreated   Task[]         @relation("TaskCreator")
  checklistRuns  ChecklistRun[]
  wasteReports   WasteReport[]
  incidents      Incident[]
  vacations      Vacation[]
  shiftSwapsFrom ShiftSwap[]    @relation("SwapFrom")
  shiftSwapsTo   ShiftSwap[]    @relation("SwapTo")
  notifications  Notification[]
  availability   Availability[]
  inventories    Inventory[]
  productions    Production[]
  sentMessages   Message[]      @relation("MessageSender")
  recvMessages   Message[]      @relation("MessageRecipient")
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  recipeAccess   RecipeAccessUser[]

  @@index([organizationId])
  @@index([organizationId, role])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  address   String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
  shifts    Shift[]
  schedules Schedule[]
  zones     Zone[]
  reservations Reservation[]

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// HARMONOGRAM
// ──────────────────────────────────────────────────────────────────────────

model Schedule {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])

  weekStart DateTime
  status    ScheduleStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]

  @@index([organizationId])
  @@index([organizationId, locationId, weekStart])
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])
  scheduleId     String?
  schedule       Schedule? @relation(fields: [scheduleId], references: [id])

  date        DateTime
  startTime   String
  endTime     String
  actualStart DateTime?
  actualEnd   DateTime?
  status      ShiftStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  swaps ShiftSwap[]

  @@index([organizationId])
  @@index([organizationId, userId, date])
  @@index([organizationId, status])
}

model ShiftSwap {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftId        String
  shift          Shift    @relation(fields: [shiftId], references: [id])
  fromUserId     String
  fromUser       User     @relation("SwapFrom", fields: [fromUserId], references: [id])
  toUserId       String?
  toUser         User?    @relation("SwapTo", fields: [toUserId], references: [id])

  status    SwapStatus @default(PENDING)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// ZADANIA & CHECKLISTY
// ──────────────────────────────────────────────────────────────────────────

model Task {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  dueTime     String?

  assigneeId String
  assignee   User   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String
  creator    User   @relation("TaskCreator", fields: [creatorId], references: [id])

  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, assigneeId, status])
}

model ChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  type      ChecklistType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items ChecklistItem[]
  runs  ChecklistRun[]

  @@index([organizationId])
}

model ChecklistItem {
  id         String   @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  text       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  completions ChecklistCompletion[]
}

model ChecklistRun {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId     String
  template       ChecklistTemplate @relation(fields: [templateId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date        DateTime @default(now())
  completedAt DateTime?
  status      ChecklistRunStatus @default(IN_PROGRESS)

  completions ChecklistCompletion[]

  @@index([organizationId])
}

model ChecklistCompletion {
  id     String   @id @default(cuid())
  runId  String
  run    ChecklistRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id])
  done   Boolean  @default(false)
  doneAt DateTime?
}

// ──────────────────────────────────────────────────────────────────────────
// OPERACJE (straty, awarie, magazyn, produkcja)
// ──────────────────────────────────────────────────────────────────────────

model WasteReport {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date        DateTime @default(now())
  product     String
  quantity    Float
  unit        String   @default("szt")
  reason      String
  costPerUnit Float    @default(0)
  totalCost   Float    @default(0)
  aiDetected  Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, date])
  @@index([organizationId, userId, createdAt])
}

model Incident {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  category    String
  device      String
  priority    Priority @default(MEDIUM)
  description String
  status      IncidentStatus @default(OPEN)
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model Vacation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  type       VacationType
  startDate  DateTime
  endDate    DateTime
  days       Int
  status     VacationStatus @default(PENDING)
  reason     String?
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean  @default(false)
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

model Message {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User     @relation("MessageRecipient", fields: [recipientId], references: [id])

  content   String
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([senderId, recipientId])
  @@index([recipientId, senderId, createdAt])
}

model Availability {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  dayOfWeek Int
  available Boolean  @default(true)
  fromTime  String?
  toTime    String?
  notes     String?
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@unique([userId, dayOfWeek])
}

model Inventory {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date       DateTime @default(now())
  product    String
  unit       String
  expected   Float
  actual     Float
  difference Float
  notes      String?
  createdAt  DateTime @default(now())

  @@index([organizationId])
}

model Production {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date      DateTime @default(now())
  product   String
  quantity  Int
  unit      String   @default("szt")
  notes     String?
  createdAt DateTime @default(now())

  @@index([organizationId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  category    String
  unit        String   @default("szt")
  costPerUnit Float    @default(0) // koszt jednostkowy (np. dla strat)
  price       Float    @default(0) // cena sprzedaży BRUTTO (do food cost %)
  vatRate     Float    @default(8) // stawka VAT % (gastronomia PL zwykle 8, napoje 23, część 5)
  description String?  // opis pozycji w menu
  available   Boolean  @default(true) // "86" — czy dostępne do zamówienia teraz
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  recipe Recipe?

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// MAGAZYN · DOSTAWCY · RECEPTURY · FOOD COST (pętla pieniędzy)
// ──────────────────────────────────────────────────────────────────────────

enum MovementType {
  PURCHASE    // przyjęcie (zakup)
  USAGE       // zużycie (produkcja/sprzedaż)
  WASTE       // strata
  ADJUSTMENT  // korekta (remanent)
  PRODUCTION  // produkcja wyrobu
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  contact   String?
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items    InventoryItem[]
  invoices Invoice[]

  @@index([organizationId])
}

model InventoryItem {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  name        String
  category    String   @default("Inne")
  unit        String   @default("kg")
  stock       Float    @default(0)   // bieżący stan
  minStock    Float    @default(0)   // poziom minimalny (alert/zamówienie)
  costPerUnit Float    @default(0)   // ostatnia cena zakupu
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipeItems  RecipeItem[]
  movements    StockMovement[]
  invoiceItems InvoiceItem[]

  @@index([organizationId])
  @@index([organizationId, category])
}

model Recipe {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId      String   @unique
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  yield     Int      @default(1) // ile sztuk wyrobu z receptury
  notes     String?

  // Pełny przepis kulinarny (oddzielony od receptury magazynowej powyżej).
  instructions String?  // opis przygotowania krok po kroku
  prepTimeMin  Int?     // czas przygotowania w minutach
  chefTips     String?  // wskazówki dla kucharzy
  cookNotes    String?  // notatki
  allergens    String[] @default([]) // alergeny
  photos       String[] @default([]) // adresy zdjęć
  fullRecipeAccess RecipeAccess @default(OWNER_ONLY) // kto widzi pełny przepis

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       RecipeItem[]
  accessUsers RecipeAccessUser[] // dla fullRecipeAccess = SELECTED

  @@index([organizationId])
}

// Kto ma dostęp do pełnego przepisu kulinarnego.
enum RecipeAccess {
  OWNER_ONLY     // tylko właściciel
  OWNER_MANAGER  // właściciel + manager
  ALL_COOKS      // wszyscy (kucharze)
  SELECTED       // wybrane osoby (accessUsers)
}

// Wybrane osoby z dostępem do pełnego przepisu (gdy fullRecipeAccess = SELECTED).
model RecipeAccessUser {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@index([userId])
}

model RecipeItem {
  id              String   @id @default(cuid())
  recipeId        String
  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantity Float  // ilość składnika na cały yield
  unit     String @default("kg")

  @@index([recipeId])
  @@index([inventoryItemId])
}

model StockMovement {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  type      MovementType
  quantity  Float    // +przyjęcie / -zużycie
  unitCost  Float?   // koszt jednostkowy przy przyjęciu
  reason    String?
  createdAt DateTime @default(now())

  @@index([organizationId, inventoryItemId])
  @@index([organizationId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// AUDYT (kto, co, kiedy) — wymóg dla operacji wrażliwych
// ──────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────
// SPRZEDAŻ / POS (źródło przychodu — finanse, marża, food cost rzeczywisty)
// ──────────────────────────────────────────────────────────────────────────

enum SaleSource {
  MANUAL // ręczne wprowadzenie
  MOCK   // generator demonstracyjny
  POS    // integracja z systemem POS
}

model PosConnection {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider   String   @default("mock") // mock | toast | square | gopos ...
  connected  Boolean  @default(false)
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sale {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?

  externalId String?    // id z systemu POS (idempotencja synchronizacji)
  serverId   String?    // kelner obsługujący (z TableOrder.openedById) — atrybucja sprzedaży/napiwków
  soldAt     DateTime   @default(now())
  total      Float      @default(0) // przychód BRUTTO (po rabacie, BEZ napiwku) — do analityki
  subtotal   Float      @default(0) // wartość pozycji przed rabatem (brutto)
  discount   Float      @default(0) // udzielony rabat
  vat        Float      @default(0) // kwota VAT zawarta w total
  tip        Float      @default(0) // napiwek (poza przychodem ze sprzedaży)
  paymentMethod String? // CASH | CARD | BLIK | ONLINE | OTHER
  splitCount Int        @default(1) // na ile osób podzielono rachunek
  source     SaleSource @default(MANUAL)
  createdAt  DateTime   @default(now())

  items SaleItem[]

  @@index([organizationId, soldAt])
  @@index([organizationId, locationId, soldAt])
  @@index([organizationId, externalId])
  @@index([organizationId, serverId, soldAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String? // denormalizowane (sprzedaż zachowuje nazwę nawet po zmianie produktu)
  name      String
  quantity  Int     @default(1)
  unitPrice Float   @default(0)
  total     Float   @default(0)
  vatRate   Float   @default(8) // stawka VAT % (do rozbicia podatku w raportach)

  @@index([saleId])
  @@index([productId])
}

// Trwałe przeglądy/analizy AI COO (historia decyzji i rekomendacji).
model CooReview {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  kind      String   @default("REVIEW") // REVIEW | CHAT
  content   String
  source    String   @default("rules") // ai | rules
  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// FAKTURY ZAKUPOWE — OCR + KSeF + automatyczna aktualizacja cen zakupu
// ──────────────────────────────────────────────────────────────────────────

enum InvoiceSource {
  MANUAL // ręczne
  OCR    // skan + ekstrakcja (Vision)
  KSEF   // Krajowy System e-Faktur
}

enum InvoiceStatus {
  PENDING   // sparsowana, czeka na potwierdzenie
  CONFIRMED // zatwierdzona → zaktualizowała magazyn i ceny
}

model KsefConnection {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nip        String?
  environment String  @default("test") // test | prod
  connected  Boolean  @default(false)
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Invoice {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  number      String?
  supplierName String?
  issueDate   DateTime?
  source      InvoiceSource @default(OCR)
  status      InvoiceStatus @default(PENDING)
  total       Float    @default(0)
  externalId  String?  // np. numer KSeF (idempotencja)
  createdAt   DateTime @default(now())
  confirmedAt DateTime?

  items InvoiceItem[]

  @@index([organizationId, status])
  @@index([organizationId, externalId])
}

model InvoiceItem {
  id              String  @id @default(cuid())
  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItemId String? // dopasowanie do pozycji magazynowej
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  name      String
  quantity  Float   @default(0)
  unit      String  @default("szt")
  unitPrice Float   @default(0)
  total     Float   @default(0)

  @@index([invoiceId])
  @@index([inventoryItemId])
}

// Alerty proaktywne (silnik reguł / AI COO) — trwała kolejka decyzji.
enum AlertStatus {
  OPEN
  DISMISSED
  RESOLVED
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  dedupeKey String        // identyfikator reguły+kontekstu (idempotencja w oknie czasu)
  type      String        // np. "low_stock", "food_cost", "labor", "variance", "incidents", "vacations"
  severity  Priority      @default(MEDIUM)
  title     String
  detail    String
  actionHref String?
  status    AlertStatus   @default(OPEN)
  metadata  Json?
  createdAt DateTime      @default(now())
  resolvedAt DateTime?

  @@index([organizationId, status, createdAt])
  @@index([organizationId, dedupeKey, status])
}

// SOP — procedury/standardy (właściciel tworzy, pracownik czyta).
model SopDocument {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title     String
  category  String   @default("Ogólne")
  content   String   // treść (markdown/plain)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, isActive])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  action     String   // np. "vacation.approve"
  entityType String   // np. "Vacation"
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([organizationId, createdAt])
}

// ===== Interaktywny plan sali i stolików + zamówienia na żywo =====

enum OrderItemKind {
  FOOD
  DRINK
}

enum OrderItemStatus {
  PENDING    // oczekuje
  PREPARING  // w przygotowaniu
  READY      // gotowe
  SERVED     // wydane
}

enum TableOrderStatus {
  OPEN
  CLOSED
}

// Strefa restauracji (np. Sala główna, Taras, Ogródek, VIP).
model Zone {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])

  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tables RestaurantTable[]

  @@index([organizationId])
  @@index([locationId])
}

// Stolik w strefie (np. W1, M2, F1).
model RestaurantTable {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  zoneId         String
  zone           Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  name      String
  seats     Int      @default(2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  orders TableOrder[]
  reservations Reservation[]

  @@index([organizationId])
  @@index([zoneId])
}

// Zamówienie/rachunek przypisany do stolika.
model TableOrder {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tableId        String
  table          RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  status     TableOrderStatus @default(OPEN)
  openedById String?
  openedAt   DateTime @default(now())
  closedAt   DateTime?
  saleId     String?  // powiązanie ze sprzedażą po zamknięciu rachunku
  total      Float    @default(0)

  items TableOrderItem[]

  @@index([organizationId, status])
  @@index([tableId])
  @@index([tableId, status])
}

// Pozycja zamówienia (jedzenie/picie) ze statusem realizacji.
model TableOrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     TableOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?  // denormalizowane (zachowuje nazwę po zmianie produktu)
  name      String
  notes     String?  // modyfikatory / uwagi (np. "bez cebuli", "dobrze wysmażone")
  kind      OrderItemKind   @default(FOOD)
  quantity  Int      @default(1)
  unitPrice Float    @default(0) // cena BRUTTO za sztukę
  vatRate   Float    @default(8) // stawka VAT % (kopiowana z produktu przy dodaniu)
  status    OrderItemStatus @default(PENDING)
  voided     Boolean  @default(false) // storno — pozycja anulowana, poza rachunkiem
  voidReason String?
  voidedById String?
  voidedAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([voidedAt])
}

// ===== Rozliczenie zmiany kasowej (cash drawer / Z-raport) =====

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  IN  // wpłata do kasy (np. rozmienienie)
  OUT // wypłata z kasy (np. drop do sejfu, zaliczka, wydatek)
}

// Zmiana kasowa: otwarcie z bilonem początkowym, ruchy gotówkowe, zamknięcie z przeliczeniem.
model CashSession {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?

  status       CashSessionStatus @default(OPEN)
  openingFloat Float    @default(0) // bilon początkowy
  openedById   String?
  openedAt     DateTime @default(now())

  closedById  String?
  closedAt    DateTime?
  cashSales   Float?    // sprzedaż gotówkowa w czasie zmiany (wyliczona)
  paidIn      Float?    // suma wpłat
  paidOut     Float?    // suma wypłat
  expectedCash Float?   // oczekiwana gotówka = bilon + sprzedaż + wpłaty − wypłaty
  countedCash Float?    // policzona gotówka
  variance    Float?    // countedCash − expectedCash (− niedobór / + nadwyżka)
  notes       String?

  movements CashMovement[]

  @@index([organizationId, status])
  @@index([organizationId, openedAt])
}

model CashMovement {
  id        String   @id @default(cuid())
  sessionId String
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      CashMovementType
  amount    Float
  reason    String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// ===== Rezerwacje =====
enum ReservationStatus {
  PENDING    // oczekuje potwierdzenia
  CONFIRMED  // potwierdzona
  SEATED     // gość posadzony
  CANCELLED  // anulowana
  NO_SHOW    // nie pojawił się
}

model Reservation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  tableId        String?
  table          RestaurantTable? @relation(fields: [tableId], references: [id])

  guestName   String
  guestPhone  String?
  partySize   Int      @default(2)
  startsAt    DateTime
  durationMin Int      @default(120)
  status      ReservationStatus @default(CONFIRMED)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId, startsAt])
  @@index([tableId])
}
