// WorkOS — AI Operating System dla gastronomii
// Schemat danych: PostgreSQL, multi-tenant (Organization), RBAC oparty na uprawnieniach.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// ENUMY (porządkowanie modeli danych — integralność na poziomie bazy)
// ──────────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  EMPLOYEE
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  ABSENT
  LATE
}

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ChecklistType {
  OPENING
  CLOSING
  CUSTOM
}

enum ChecklistRunStatus {
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VacationType {
  ANNUAL
  ON_DEMAND
  UNPAID
  SICK
  OTHER
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TASK
  SCHEDULE
  VACATION
}

// ──────────────────────────────────────────────────────────────────────────
// TENANT
// ──────────────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE") // FREE | PRO | ENTERPRISE
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  locations          Location[]
  schedules          Schedule[]
  shifts             Shift[]
  shiftSwaps         ShiftSwap[]
  tasks              Task[]
  checklistTemplates ChecklistTemplate[]
  checklistRuns      ChecklistRun[]
  wasteReports       WasteReport[]
  incidents          Incident[]
  vacations          Vacation[]
  notifications      Notification[]
  messages           Message[]
  availability       Availability[]
  inventories        Inventory[]
  productions        Production[]
  products           Product[]
  auditLogs          AuditLog[]
}

// ──────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  email       String   @unique
  password    String
  role        Role     @default(EMPLOYEE)
  permissions String[] @default([]) // dodatkowe uprawnienia nadane pracownikowi
  avatar      String?
  phone       String?
  position    String?
  hireDate    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  shifts         Shift[]
  tasks          Task[]         @relation("TaskAssignee")
  tasksCreated   Task[]         @relation("TaskCreator")
  checklistRuns  ChecklistRun[]
  wasteReports   WasteReport[]
  incidents      Incident[]
  vacations      Vacation[]
  shiftSwapsFrom ShiftSwap[]    @relation("SwapFrom")
  shiftSwapsTo   ShiftSwap[]    @relation("SwapTo")
  notifications  Notification[]
  availability   Availability[]
  inventories    Inventory[]
  productions    Production[]
  sentMessages   Message[]      @relation("MessageSender")
  recvMessages   Message[]      @relation("MessageRecipient")
  auditLogs      AuditLog[]

  @@index([organizationId])
  @@index([organizationId, role])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  address   String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
  shifts    Shift[]
  schedules Schedule[]

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// HARMONOGRAM
// ──────────────────────────────────────────────────────────────────────────

model Schedule {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])

  weekStart DateTime
  status    ScheduleStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts Shift[]

  @@index([organizationId])
  @@index([organizationId, locationId, weekStart])
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])
  scheduleId     String?
  schedule       Schedule? @relation(fields: [scheduleId], references: [id])

  date        DateTime
  startTime   String
  endTime     String
  actualStart DateTime?
  actualEnd   DateTime?
  status      ShiftStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  swaps ShiftSwap[]

  @@index([organizationId])
  @@index([organizationId, userId, date])
  @@index([organizationId, status])
}

model ShiftSwap {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftId        String
  shift          Shift    @relation(fields: [shiftId], references: [id])
  fromUserId     String
  fromUser       User     @relation("SwapFrom", fields: [fromUserId], references: [id])
  toUserId       String?
  toUser         User?    @relation("SwapTo", fields: [toUserId], references: [id])

  status    SwapStatus @default(PENDING)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// ZADANIA & CHECKLISTY
// ──────────────────────────────────────────────────────────────────────────

model Task {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  dueTime     String?

  assigneeId String
  assignee   User   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId  String
  creator    User   @relation("TaskCreator", fields: [creatorId], references: [id])

  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, assigneeId, status])
}

model ChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  type      ChecklistType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items ChecklistItem[]
  runs  ChecklistRun[]

  @@index([organizationId])
}

model ChecklistItem {
  id         String   @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  text       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  completions ChecklistCompletion[]
}

model ChecklistRun {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId     String
  template       ChecklistTemplate @relation(fields: [templateId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date        DateTime @default(now())
  completedAt DateTime?
  status      ChecklistRunStatus @default(IN_PROGRESS)

  completions ChecklistCompletion[]

  @@index([organizationId])
}

model ChecklistCompletion {
  id     String   @id @default(cuid())
  runId  String
  run    ChecklistRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id])
  done   Boolean  @default(false)
  doneAt DateTime?
}

// ──────────────────────────────────────────────────────────────────────────
// OPERACJE (straty, awarie, magazyn, produkcja)
// ──────────────────────────────────────────────────────────────────────────

model WasteReport {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date        DateTime @default(now())
  product     String
  quantity    Float
  unit        String   @default("szt")
  reason      String
  costPerUnit Float    @default(0)
  totalCost   Float    @default(0)
  aiDetected  Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, date])
}

model Incident {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  category    String
  device      String
  priority    Priority @default(MEDIUM)
  description String
  status      IncidentStatus @default(OPEN)
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model Vacation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  type       VacationType
  startDate  DateTime
  endDate    DateTime
  days       Int
  status     VacationStatus @default(PENDING)
  reason     String?
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean  @default(false)
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId, read])
}

model Message {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User     @relation("MessageRecipient", fields: [recipientId], references: [id])

  content   String
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([senderId, recipientId])
}

model Availability {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  dayOfWeek Int
  available Boolean  @default(true)
  fromTime  String?
  toTime    String?
  notes     String?
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@unique([userId, dayOfWeek])
}

model Inventory {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date       DateTime @default(now())
  product    String
  unit       String
  expected   Float
  actual     Float
  difference Float
  notes      String?
  createdAt  DateTime @default(now())

  @@index([organizationId])
}

model Production {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  date      DateTime @default(now())
  product   String
  quantity  Int
  unit      String   @default("szt")
  notes     String?
  createdAt DateTime @default(now())

  @@index([organizationId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  category    String
  unit        String   @default("szt")
  costPerUnit Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([organizationId])
}

// ──────────────────────────────────────────────────────────────────────────
// AUDYT (kto, co, kiedy) — wymóg dla operacji wrażliwych
// ──────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  action     String   // np. "vacation.approve"
  entityType String   // np. "Vacation"
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([organizationId, createdAt])
}
